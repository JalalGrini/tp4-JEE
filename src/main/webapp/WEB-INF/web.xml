<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         id="WebApp_ID" version="4.0">

    <display-name>GestionDesProduitsMVC1</display-name>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filters.SessionFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>ListProduits</servlet-name>
        <servlet-class>web.ListProduitsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListProduits</servlet-name>
        <url-pattern>/listProduits</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddProduit</servlet-name>
        <servlet-class>web.AddProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddProduit</servlet-name>
        <url-pattern>/addProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditProduit</servlet-name>
        <servlet-class>web.EditProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditProduit</servlet-name>
        <url-pattern>/editProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteProduit</servlet-name>
        <servlet-class>web.DeleteProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteProduit</servlet-name>
        <url-pattern>/deleteProduit</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>UpdateProduit</servlet-name>
        <servlet-class>web.UpdateProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProduit</servlet-name>
        <url-pattern>/updateProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>web.loginhandler</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/loginhandler</url-pattern>
    </servlet-mapping>

</web-app>